# ---------------------------------------------------------------------------
# Hashnode blog integration
# ---------------------------------------------------------------------------

# Hashnode publication host to pull posts from.
NEXT_PUBLIC_HASHNODE_HOST=durubuildinfra.hashnode.dev

# Public site URL — used to build canonical + OpenGraph URLs for SEO.
NEXT_PUBLIC_SITE_URL=https://durainfra.com

# Secret for the on-demand revalidation webhook (/api/revalidate).
# Generate a strong random value, e.g.  openssl rand -hex 32
# Then add a Hashnode webhook pointing to:
#   https://<your-domain>/api/revalidate?secret=<this-value>
HASHNODE_REVALIDATE_SECRET=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# Contact form (Web3Forms)
# ---------------------------------------------------------------------------

# Public Web3Forms access key — used by the contact form to deliver email.
# Safe to expose client-side. Get/manage it at https://web3forms.com
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=6017c6cb-c86f-4800-bb05-06e6c18d7053
